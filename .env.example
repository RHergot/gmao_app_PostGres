# Configuration GMAO app_PostGres
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données
DATABASE_TYPE=postgres
POSTGRES_DB=gmao_industrie_data
POSTGRES_USER=gmao_app_user
POSTGRES_PASSWORD=mot_de_passe_fort
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Logging
LOG_LEVEL=INFO

# Mot de passe administrateur initial (pour le premier démarrage)
INITIAL_ADMIN_PASSWORD=

# BI Reporting (optionnel)
GMAO_BI_REPORTING_PATH=
