{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Django Development Server",
			"type": "shell",
			"command": ".venv/Scripts/python.exe",
			"args": [
				"manage.py",
				"runserver",
				"0.0.0.0:8000"
			],
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				"$eslint-stylish"
			]
		}
	]
}